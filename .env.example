# Database
DATABASE_URL="postgresql://username:password@localhost:5432/epabusinessplatform?schema=public"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-a-random-string"

# Azure AD B2C (EPA MAX) Configuration
AZURE_AD_B2C_TENANT_NAME="your-tenant-name"
AZURE_AD_B2C_CLIENT_ID="your-client-id"
AZURE_AD_B2C_CLIENT_SECRET="your-client-secret"
AZURE_AD_B2C_PRIMARY_USER_FLOW="B2C_1_signupsignin1"

# Microsoft Graph API
MS_GRAPH_CLIENT_ID="your-graph-client-id"
MS_GRAPH_CLIENT_SECRET="your-graph-client-secret"
MS_GRAPH_TENANT_ID="your-tenant-id"

# AI Service Configuration
# Supports OpenAI-compatible APIs including:
# - OpenAI API (https://api.openai.com/v1)
# - Azure OpenAI
# - Local models via ngrok (e.g., https://demandingly-superangelic-dusty.ngrok-free.dev/v1)
# - Ollama, LM Studio, etc.

AI_SERVICE_URL="https://demandingly-superangelic-dusty.ngrok-free.dev/v1"
AI_API_KEY="your-openai-api-key-or-ngrok-token"
AI_MODEL="gpt-3.5-turbo"
AI_SERVICE_TIMEOUT="5000"
ENABLE_AI_CONVERSION="true"

# Teams Bot
BOT_APP_ID="your-bot-app-id"
BOT_APP_PASSWORD="your-bot-app-password"
BOT_CHANNEL_SERVICE="https://botframework.azure.us"  # For government cloud

# Application Settings
APP_NAME="EPA Business Platform"
APP_LOGO="/assets/epa-logo.svg"
DEFAULT_PROMPT_TEMPLATE="v1"

# Audit & Compliance
AUDIT_LOG_RETENTION_DAYS="2555"  # 7 years for federal compliance
ENABLE_DETAILED_AUDIT="true"
PII_MASKING_ENABLED="true"

# Security
SESSION_MAX_AGE="28800"  # 8 hours in seconds
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MINUTES="30"

# Feature Flags
ENABLE_TEAMS_BOT="true"
ENABLE_AI_CONVERSION="true"
ENABLE_ONE_NOTE_PUBLISH="true"
ENABLE_AUDIT_LOGGING="true"
ENABLE_ENHANCED_CONTRACT_SUBMISSIONS="true"

# Redis (for production caching)
# REDIS_URL="redis://localhost:6379"

# AWS S3 (for file storage in production)
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-gov-west-1"
# S3_BUCKET_NAME="epa-business-platform-uploads"

# Email (for notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@epa.gov"
# SMTP_PASS="your-app-password"

# Monitoring
# SENTRY_DSN="your-sentry-dsn"
# LOG_LEVEL="info"
