// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  CONTRIBUTOR
  AGGREGATOR
  PROGRAM_OVERSEER
  ADMINISTRATOR
}

enum SubmissionStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}

enum WorkflowStage {
  SUBMISSION
  REVIEW
  APPROVAL
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

// User model - synced with Azure AD
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  azureAdId     String    @unique
  role          Role      @default(CONTRIBUTOR)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  submissions   Submission[]
  reviews       Review[]
  auditLogs     AuditLog[]
  projectAssignments ProjectAssignment[]
  // Teams notification fields
  teamsNotificationsEnabled  Boolean  @default(true)
  teamsConversationId      String?
  teamsConversationReference String?
  
  @@map("users")
}

// Weekly Activity Report Submission
model Submission {
  id                String           @id @default(cuid())
  userId            String
  projectId         String?
  componentId       String?
  weekOf            DateTime
  rawText           String
  terseVersion      String?
  aiConfidence      Float?
  status            SubmissionStatus @default(SUBMITTED)
  isAiGenerated     Boolean          @default(true)
  editedBy          String?
  publishedAt       DateTime?
  oneNotePageId     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  // Relations
  user              User             @relation(fields: [userId], references: [id])
  project           Project?         @relation(fields: [projectId], references: [id])
  component         ProjectComponent? @relation(fields: [componentId], references: [id])
  reviews           Review[]
  workflowState     WorkflowState?
  auditLogs         AuditLog[]
  
  @@index([userId])
  @@index([projectId])
  @@index([componentId])
  @@index([weekOf])
  @@index([status])
  @@map("submissions")
}

// Review records (Jake's edits)
model Review {
  id                String   @id @default(cuid())
  submissionId      String
  reviewerId        String
  originalText      String
  editedText        String
  editReason        String?
  createdAt         DateTime @default(now())
  
  // Relations
  submission        Submission @relation(fields: [submissionId], references: [id])
  reviewer          User       @relation(fields: [reviewerId], references: [id])
  auditLogs         AuditLog[]
  
  @@index([submissionId])
  @@map("reviews")
}

// Workflow state tracking
model WorkflowState {
  id                String        @id @default(cuid())
  submissionId      String        @unique
  currentStage      WorkflowStage @default(SUBMISSION)
  assignedTo        String?
  dueDate           DateTime?
  notes             String?
  updatedAt         DateTime      @updatedAt
  
  // Relations
  submission        Submission    @relation(fields: [submissionId], references: [id])
  
  @@map("workflow_states")
}

// AI Prompt Templates (Jake can customize)
model PromptTemplate {
  id                String   @id @default(cuid())
  name              String   @unique
  version           Int      @default(1)
  content           String
  isActive          Boolean  @default(true)
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([isActive])
  @@map("prompt_templates")
}

// Audit Log for compliance
model AuditLog {
  id                String   @id @default(cuid())
  action            String
  userId            String?
  resourceType      String
  resourceId        String?
  metadata          Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  
  // Relations
  user              User?    @relation(fields: [userId], references: [id])
  submission        Submission? @relation(fields: [resourceId], references: [id], map: "audit_submission")
  review            Review?   @relation(fields: [resourceId], references: [id], map: "audit_review")
  
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// Notifications
model Notification {
  id                String    @id @default(cuid())
  userId            String
  type              String
  title             String
  message           String
  isRead            Boolean   @default(false)
  metadata          Json?
  createdAt         DateTime  @default(now())
  
  // Relations
  user              User      @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// Teams Bot Conversation State
model ConversationState {
  id                String   @id @default(cuid())
  conversationId    String   @unique
  userId            String
  lastMessage       String?
  context           Json?
  updatedAt         DateTime @updatedAt
  
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_states")
}

// Project management for multi-contributor reports
model Project {
  id                String           @id @default(cuid())
  name              String
  description       String?
  status            ProjectStatus    @default(ACTIVE)
  createdBy         String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  // Relations
  components        ProjectComponent[]
  assignments       ProjectAssignment[]
  submissions       Submission[]
  
  @@index([status])
  @@map("projects")
}

// Project components (e.g., "Backend API", "Frontend UI" within a project)
model ProjectComponent {
  id                String           @id @default(cuid())
  projectId         String
  name              String
  description       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  // Relations
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions       Submission[]
  assignments       ProjectAssignment[]
  
  @@index([projectId])
  @@map("project_components")
}

// Many-to-many relationship between Users and Projects/Components
model ProjectAssignment {
  id                String           @id @default(cuid())
  userId            String
  projectId         String
  componentId       String?
  assignedBy        String?
  assignedAt        DateTime         @default(now())
  
  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  component         ProjectComponent? @relation(fields: [componentId], references: [id], onDelete: Cascade)
  
  @@unique([userId, projectId, componentId])
  @@index([userId])
  @@index([projectId])
  @@map("project_assignments")
}
