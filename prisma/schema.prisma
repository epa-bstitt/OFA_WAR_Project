generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                         String              @id @default(cuid())
  email                      String              @unique
  name                       String?
  azureAdId                  String              @unique
  role                       String              @default("CONTRIBUTOR")
  isActive                   Boolean             @default(true)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  teamsNotificationsEnabled  Boolean             @default(true)
  teamsConversationId        String?
  teamsConversationReference String?
  submissions                Submission[]
  reviews                    Review[]
  auditLogs                  AuditLog[]
  projectAssignments         ProjectAssignment[]
  notifications              Notification[]
  assignedContracts          Contract[]          @relation("ContractAssignee")

  @@map("users")
}

model Contract {
  id                     String       @id @default(cuid())
  contractName           String
  category               String
  assigneeId             String?
  imageUrl               String?
  imageAlt               String?
  cor                    String?
  contractNumber         String?
  office                 String?
  nextPeriodOfPerf       String?
  ultimateCompletionDate String?
  co                     String?
  cs                     String?
  orderNumber            String?
  currentUpdatePlaceholder String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  assignee               User?        @relation("ContractAssignee", fields: [assigneeId], references: [id])
  submissions            Submission[]

  @@index([assigneeId])
  @@index([category])
  @@map("contracts")
}

model Submission {
  id            String            @id @default(cuid())
  userId        String
  projectId     String?
  componentId   String?
  contractId    String?
  weekOf        DateTime
  rawText       String
  terseText     String?
  terseVersion  String?
  aiConfidence  Float?
  status        String            @default("SUBMITTED")
  isAiGenerated Boolean           @default(true)
  editedBy      String?
  publishedAt   DateTime?
  oneNotePageId String?
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id])
  project       Project?          @relation(fields: [projectId], references: [id])
  component     ProjectComponent? @relation(fields: [componentId], references: [id])
  contract      Contract?         @relation(fields: [contractId], references: [id])
  reviews       Review[]
  workflowState WorkflowState?

  @@index([userId])
  @@index([projectId])
  @@index([componentId])
  @@index([contractId])
  @@index([weekOf])
  @@index([status])
  @@map("submissions")
}

model Review {
  id           String   @id @default(cuid())
  submissionId String
  reviewerId   String
  status       String
  comment      String?
  originalText String?
  editedText   String?
  editReason   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id])
  reviewer     User     @relation(fields: [reviewerId], references: [id])

  @@index([submissionId])
  @@index([reviewerId])
  @@map("reviews")
}

model WorkflowState {
  id           String   @id @default(cuid())
  submissionId String   @unique
  currentStage String   @default("SUBMISSION")
  assignedTo   String?
  dueDate      DateTime?
  notes        String?
  updatedAt    DateTime @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id])

  @@map("workflow_states")
}

model PromptTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  version   Int      @default(1)
  content   String
  isActive  Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("prompt_templates")
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  userId       String?
  resourceType String
  resourceId   String?
  metadata     String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resourceId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model ConversationState {
  id             String   @id @default(cuid())
  conversationId String   @unique
  userId         String
  lastMessage    String?
  context        String?
  updatedAt      DateTime @updatedAt

  @@index([conversationId])
  @@index([userId])
  @@map("conversation_states")
}

model Project {
  id          String              @id @default(cuid())
  name        String
  description String?
  status      String              @default("ACTIVE")
  createdBy   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  components  ProjectComponent[]
  assignments ProjectAssignment[]
  submissions Submission[]

  @@index([status])
  @@map("projects")
}

model ProjectComponent {
  id          String              @id @default(cuid())
  projectId   String
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions Submission[]
  assignments ProjectAssignment[]

  @@index([projectId])
  @@map("project_components")
}

model ProjectAssignment {
  id          String            @id @default(cuid())
  userId      String
  projectId   String
  componentId String?
  assignedBy  String?
  assignedAt  DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  component   ProjectComponent? @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId, componentId])
  @@index([userId])
  @@index([projectId])
  @@map("project_assignments")
}
